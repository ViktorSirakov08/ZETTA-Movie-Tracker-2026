# Postgres
POSTGRES_USER=<your-postgres-user>
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=movie_tracker
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=<your-minio-root-user>
MINIO_ROOT_PASSWORD=<your-minio-root-password>
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Elasticsearch / Kibana
ELASTIC_PORT=9200
KIBANA_PORT=5601

# App ports
BACKEND_PORT=3000
FRONTEND_PORT=5173
ADMINER_PORT=8081

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Override to send through a real SMTP provider instead of Mailpit.
# Leave unset to keep using Mailpit (the defaults baked into docker-compose.yml).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
