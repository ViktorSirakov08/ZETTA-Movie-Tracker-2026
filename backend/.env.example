NODE_ENV=development

# PostgreSQL (matches docker-compose.yml at the repo root)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=movie_tracker

# JWT — short-lived access token, renewed silently via the refresh token
# below rather than forcing a re-login every time it expires.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Elasticsearch (matches docker-compose.yml at the repo root)
ELASTICSEARCH_NODE=http://localhost:9200

# MinIO (matches docker-compose.yml at the repo root)
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin-movie-tracker
MINIO_BUCKET=posters
